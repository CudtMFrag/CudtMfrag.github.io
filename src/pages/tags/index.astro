---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
const maxCount = Math.max(...tagCounts.values(), 1);

function tagScale(count: number): string {
  const ratio = count / maxCount;
  if (ratio >= 0.8) return 'tag-xl';
  if (ratio >= 0.5) return 'tag-lg';
  if (ratio >= 0.3) return 'tag-md';
  return 'tag-sm';
}
---

<BaseLayout title="标签">
  <div class="tags-header">
    <h2 class="tags-heading">标签</h2>
    <p class="tags-sub">{sortedTags.length} 个标签，{posts.length} 篇文章</p>
  </div>
  <div class="tags-cloud">
    {sortedTags.map(([tag, count]) => (
      <a href={`/tags/${tag}/`} class={`tag-pill ${tagScale(count)}`}>
        {tag}
        <span class="tag-count">{count}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .tags-header {
    margin-bottom: 2rem;
  }
  .tags-heading {
    font-size: 1.5rem;
    font-weight: var(--h2-weight);
    color: var(--color-base-100);
    letter-spacing: -0.02em;
  }
  .tags-sub {
    margin-top: 0.375rem;
    color: var(--text-faint);
    font-size: var(--font-small);
  }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-l);
    color: var(--text-muted);
    font-weight: var(--font-medium);
    transition: all var(--anim-fast) var(--ease-out);
    white-space: nowrap;
  }
  .tag-pill:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: oklch(from var(--color-accent) l c h / 0.06);
    text-decoration: none;
  }

  .tag-sm { font-size: 0.8125rem; padding: 0.25rem 0.75rem; }
  .tag-md { font-size: 0.875rem;  padding: 0.3rem 0.875rem; }
  .tag-lg { font-size: 0.9375rem; padding: 0.375rem 1rem; }
  .tag-xl { font-size: 1.0625rem; padding: 0.45rem 1.125rem; }

  .tag-count {
    font-size: 0.75em;
    color: var(--text-faint);
    font-weight: var(--font-normal);
  }
  .tag-pill:hover .tag-count {
    color: var(--color-accent);
  }
</style>
