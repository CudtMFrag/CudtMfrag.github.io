---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

function stripMarkdown(text: string): string {
  return text
    .replace(/^#+\s/gm, '')
    .replace(/[*_~`>]/g, '')
    .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
    .replace(/\n/g, ' ')
    .trim();
}

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const perPage = 10;
const currentPosts = sortedPosts.slice(0, perPage);
const totalPages = Math.ceil(sortedPosts.length / perPage);
---

<BaseLayout>
  <div class="post-list">
    {currentPosts.map(post => (
      <div class="post-item">
        <a class="post-item-title" href={`/${post.data.date.getFullYear()}/${String(post.data.date.getMonth() + 1).padStart(2, '0')}/${String(post.data.date.getDate()).padStart(2, '0')}/${post.id.replace('.md', '')}/`}>
          {post.data.title}
        </a>
        <div class="post-item-meta">
          <span>{post.data.date.toISOString().slice(0, 10).replace(/-/g, '.')}</span>
          {post.data.tags.length > 0 && (
            <span>{post.data.tags.map(tag => <a class="tag-badge" href={`/tags/${tag}/`}>#{tag}</a>)}</span>
          )}
        </div>
        <div class="post-item-excerpt">
          {post.body ? stripMarkdown(post.body).slice(0, 200) + '...' : ''}
        </div>
      </div>
    ))}
  </div>
  {totalPages > 1 && (
    <div class="paginator">
      <span class="current">1</span>
      <span>/</span>
      <span>{totalPages}</span>
      {totalPages > 1 && <a href="/page/2/">下一页</a>}
    </div>
  )}
</BaseLayout>
