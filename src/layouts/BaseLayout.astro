---
export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = "Ryle's bbbblog!!!";
const siteSubtitle = "Don't be evil.";
const siteDesc = description || "是博客呀";
---

<!DOCTYPE html>
<html lang="zh-Hans">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={siteDesc} />
  <meta name="author" content="Li Ryle" />
  <title>{title ? `${title} — ${siteTitle}` : siteTitle} — {siteSubtitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="bg-glow"></div>
  <div class="paper">
    <div class="paper-main">
      <header class="header">
        <a href="/" class="logo">{siteTitle}</a>
        <nav class="nav">
          <a href="/">首页</a>
          <a href="/archives/">归档</a>
          <a href="/tags/">标签</a>
          <a href="/about/">关于</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer">
        <p>Copyright &copy; {new Date().getFullYear()} {siteTitle}</p>
        <p class="footer-muted">
          <a href="/rss.xml">RSS</a>
          <span>&middot;</span>
          <a href="https://github.com/CudtMFrag/CudtMFrag.github.io">Source</a>
        </p>
      </footer>
    </div>
  </div>
</body>
</html>

<style is:global>
  /* ===========================
     Velocity Design System
     =========================== */

  :root {
    /* Base hue: purple-violet tint, matching Velocity */
    --bhue: 281;

    /* Light mode base lightness scale */
    --bl-00: 99%;
    --bl-05: 97.5%;
    --bl-10: 96.2%;
    --bl-20: 92%;
    --bl-25: 88.25%;
    --bl-30: 85.75%;
    --bl-35: 82.5%;
    --bl-40: 75.25%;
    --bl-50: 71.5%;
    --bl-55: 65%;
    --bl-60: 55.75%;
    --bl-70: 46.5%;
    --bl-80: 40%;
    --bl-90: 30%;
    --bl-100: 24%;

    /* Saturation values from Velocity light */
    --bsat-xtr: 0.0105;
    --bsat-str: 0.0025;
    --bsat-med: 0.0015;
    --bsat-low: 0.0005;

    /* Accent: blue at 212deg, matching Velocity */
    --accent-h: 212;
    --accent-s: 100%;
    --accent-l: 52%;

    /* Colors */
    --color-accent: oklch(var(--accent-l) var(--accent-s) var(--accent-h));
    --color-accent-1: color-mix(in oklab, var(--color-accent), white 7.5%);

    /* Base gray scale (purple-tinted) */
    --color-base-00: oklch(var(--bl-00) var(--bsat-low) var(--bhue));
    --color-base-05: oklch(var(--bl-05) var(--bsat-low) var(--bhue));
    --color-base-10: oklch(var(--bl-10) var(--bsat-str) var(--bhue));
    --color-base-20: oklch(var(--bl-20) var(--bsat-str) var(--bhue));
    --color-base-25: oklch(var(--bl-25) var(--bsat-str) var(--bhue));
    --color-base-30: oklch(var(--bl-30) var(--bsat-str) var(--bhue));
    --color-base-50: oklch(var(--bl-50) var(--bsat-xtr) var(--bhue));
    --color-base-60: oklch(var(--bl-60) var(--bsat-xtr) var(--bhue));
    --color-base-80: oklch(var(--bl-80) var(--bsat-str) var(--bhue));
    --color-base-90: oklch(var(--bl-90) var(--bsat-low) var(--bhue));
    --color-base-100: oklch(var(--bl-100) var(--bsat-low) var(--bhue));

    /* Semantic tokens */
    --bg-body: oklch(94.5% 0.00625 var(--bhue));
    --bg-card: oklch(99% 0.00125 var(--bhue));
    --bg-card-hover: oklch(100% 0 var(--bhue));
    --text-normal: var(--color-base-90);
    --text-muted: var(--color-base-60);
    --text-faint: var(--color-base-50);
    --border-color: oklch(0% 0 0 / 0.0625);
    --border-strong: oklch(0% 0 0 / 0.092);

    /* Glass & shadows from Velocity */
    --trans-faint-10: oklch(5% 0 0 / 0.055);
    --trans-faint-20: oklch(0% 0 0 / 0.0625);
    --trans-faint-25: oklch(0% 0 0 / 0.07);
    --trans-faint-30: oklch(0% 0 0 / 0.092);
    --trans-faint-40: oklch(0% 0 0 / 0.1125);
    --trans-strong-30: oklch(100% 0 0 / 0.4);

    --glass-base: inset 1px 1px 2px 0 var(--trans-strong-30), inset -1px -1px 2px 0 var(--trans-strong-30);
    --shadow-faint: 0px 0 12px 0px var(--trans-faint-10);
    --shadow-muted: 0px 3px 18px 0px var(--trans-faint-25);
    --shadow-normal: 0px 0px 5px 0px var(--trans-faint-10), 0px 10px 20px 0px var(--trans-faint-25);
    --shadow-strong: 0px 1.25px 6.25px rgba(0,0,0,0.08), 0px 3px 12px rgba(0,0,0,0.06), 0px 16px 32px rgba(0,0,0,0.12);
    --shadow-card: var(--glass-base), var(--shadow-normal);
    --shadow-card-hover: var(--glass-base), var(--shadow-strong);

    /* Typography */
    --font-family: "Inter", -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", "Hiragino Sans", "Microsoft YaHei", sans-serif;
    --font-mono: "SF Mono", "Cascadia Code", "Fira Code", "JetBrains Mono", monospace;

    --font-thin: 270;
    --font-light: 320;
    --font-normal: 420;
    --font-medium: 520;
    --font-semibold: 620;
    --font-bold: 720;

    /* Heading weights from Velocity: thin H1, semi-bold H2-H4 */
    --h1-weight: 330;
    --h2-weight: 570;
    --h3-weight: 570;
    --h4-weight: 570;
    --h5-weight: 620;
    --h6-weight: 670;

    --h1-size: 2em;
    --h2-size: 1.5em;
    --h3-size: 1.375em;
    --h4-size: 1.25em;
    --h5-size: 1.125em;
    --h6-size: 1em;

    --line-height: 1.6;
    --font-small: 0.90625em;

    /* Radius from Velocity */
    --radius-xs: 6px;
    --radius-s: 8px;
    --radius-m: 12px;
    --radius-l: 18px;
    --radius-xl: 20px;
    --radius-xxl: 22px;

    /* Animation from Velocity */
    --anim-fast: 150ms;
    --anim-superfast: 75ms;
    --ease-out: cubic-bezier(0.3, 0.75, 0, 1);

    /* Layout */
    --content-width: 43.75rem;
    --content-padding: 5vw;
  }

  /* ===========================
     Dark mode (Velocity dark)
     =========================== */
  @media (prefers-color-scheme: dark) {
    :root {
      --bl-00: 23.5%;
      --bl-05: 24.0%;
      --bl-10: 26.25%;
      --bl-20: 27.5%;
      --bl-25: 31.25%;
      --bl-30: 34.5%;
      --bl-35: 36.25%;
      --bl-40: 43.75%;
      --bl-50: 52.5%;
      --bl-55: 57.5%;
      --bl-60: 63.75%;
      --bl-70: 71.25%;
      --bl-80: 77.5%;
      --bl-90: 85.0%;
      --bl-100: 93.25%;

      --bsat-xtr: 0.0075;
      --bsat-str: 0.00375;
      --bsat-med: 0.00125;
      --bsat-low: 0;
      --bsat-trans: 1;

      --accent-s: 86%;
      --accent-l: 52%;

      --color-accent: oklch(var(--accent-l) var(--accent-s) var(--accent-h));
      --color-accent-1: color-mix(in oklab, var(--color-accent) 64%, #fff 36%);

      --bg-body: oklch(26.25% var(--bsat-str) var(--bhue));
      --bg-card: oklch(27% var(--bsat-str) var(--bhue));

      --border-color: oklch(100% calc(var(--bsat-trans) * 0.05) var(--bhue) / 0.0625);
      --border-strong: oklch(100% calc(var(--bsat-trans) * 0.075) var(--bhue) / 0.1);

      --glass-base: inset 0.875px 1.625px 2px -1px rgba(255,255,255,0.15), inset -0.875px -1.625px 2px -1px rgba(255,255,255,0.1), inset 0 8px 16px rgba(255,255,255,0.015);

      --shadow-faint: 0px 3px 15px 0px rgba(0,0,0,0.15);
      --shadow-muted: 0px 3px 18px 0px rgba(0,0,0,0.1875);
      --shadow-normal: 0px 3px 18px 0px rgba(0,0,0,0.1875);
      --shadow-strong: 0px 0px 24px 0px rgba(0,0,0,0.375);

      --code-bg: oklch(100% 0.05 281 / 0.0625);
    }
  }

  /* ===========================
     Base Reset
     =========================== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    font-family: var(--font-family);
    font-size: 16px;
    line-height: var(--line-height);
    color: var(--text-normal);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    background: var(--bg-body);
    min-height: 100vh;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--anim-fast) var(--ease-out);
  }
  a:hover { color: var(--color-accent-1); }

  /* ===========================
     Ambient background glow
     =========================== */
  .bg-glow {
    position: fixed;
    top: -50vh;
    left: -50vw;
    width: 200vw;
    height: 200vh;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse at 50% 0%, oklch(from var(--color-accent) l c h / 0.04) 0%, transparent 60%);
  }

  /* ===========================
     Paper card (glass morphism)
     =========================== */
  .paper {
    position: relative;
    z-index: 1;
    padding: 4vw;
  }

  .paper-main {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 3.5rem var(--content-padding) 0;
    background: var(--bg-card);
    border-radius: var(--radius-xxl);
    box-shadow: var(--shadow-card);
  }

  /* ===========================
     Header
     =========================== */
  .header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }

  .logo {
    font-size: 1.5rem;
    font-weight: var(--font-semibold);
    color: var(--color-base-100);
    letter-spacing: -0.02em;
  }
  .logo:hover { color: var(--color-base-100); }

  .nav {
    display: flex;
    gap: 1.5rem;
    list-style: none;
  }
  .nav a {
    color: var(--text-muted);
    font-size: var(--font-small);
    font-weight: var(--font-normal);
    transition: color var(--anim-fast) var(--ease-out);
  }
  .nav a:hover {
    color: var(--text-normal);
    text-decoration: none;
  }

  /* ===========================
     Footer
     =========================== */
  .footer {
    padding: 3.5rem 0 2rem;
    text-align: center;
    color: var(--text-faint);
    font-size: var(--font-small);
  }
  .footer a { color: var(--text-muted); }
  .footer a:hover { color: var(--text-normal); }
  .footer-muted { margin-top: 0.25rem; display: flex; gap: 0.5rem; justify-content: center; align-items: center; }

  /* ===========================
     Post list
     =========================== */
  .post-list { display: flex; flex-direction: column; gap: 1.5rem; }

  .post-item {
    padding: 1rem 0 1.5rem;
    border-bottom: 1px solid var(--border-color);
    transition: transform var(--anim-fast) var(--ease-out);
  }

  .post-item-title {
    font-size: 1.3rem;
    font-weight: var(--font-semibold);
    color: var(--color-base-100);
    display: block;
    margin-bottom: 0.375rem;
    letter-spacing: -0.01em;
  }
  .post-item-title:hover { color: var(--color-accent); text-decoration: none; }

  .post-item-meta {
    font-size: var(--font-small);
    color: var(--text-faint);
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .post-item-excerpt {
    color: var(--text-muted);
    font-size: var(--font-small);
  }

  /* ===========================
     Tag page header
     =========================== */
  .tag-page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-color);
  }
  .tag-page-title {
    font-size: 1.5rem;
    font-weight: var(--h2-weight);
    color: var(--color-base-100);
    letter-spacing: -0.02em;
  }
  .tag-page-count {
    margin-top: 0.25rem;
    color: var(--text-faint);
    font-size: var(--font-small);
  }

  /* ===========================
     Tags
     =========================== */
  .tag-badge {
    display: inline-flex;
    align-items: center;
    background: oklch(from var(--color-accent) l c h / 0.05);
    border: 1px solid oklch(from var(--color-accent) l c h / 0.12);
    border-left: 2px solid oklch(from var(--color-accent) l c h / 0.4);
    padding: 0.2rem 0.625rem;
    border-radius: var(--radius-xs);
    font-size: 0.75rem;
    font-weight: var(--font-medium);
    color: var(--text-muted);
    transition: all var(--anim-fast) var(--ease-out);
  }
  .tag-badge:hover {
    background: oklch(from var(--color-accent) l c h / 0.1);
    border-color: oklch(from var(--color-accent) l c h / 0.25);
    border-left-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  .tag-emoji {
    margin-right: 4px;
    color: var(--text-faint);
  }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 2rem 0;
  }
  .tags-cloud a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 1rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-l);
    font-size: var(--font-small);
    font-weight: var(--font-medium);
    color: var(--text-muted);
    transition: all var(--anim-fast) var(--ease-out);
  }
  .tags-cloud a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: oklch(from var(--color-accent) l c h / 0.06);
    text-decoration: none;
  }

  /* ===========================
     Pagination
     =========================== */
  .paginator {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    padding: 2.5rem 0 0;
    align-items: center;
    font-size: var(--font-small);
  }
  .paginator a {
    padding: 0.4rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-l);
    color: var(--text-muted);
    transition: all var(--anim-fast) var(--ease-out);
  }
  .paginator a:hover {
    background: var(--border-color);
    color: var(--text-normal);
    text-decoration: none;
  }
  .paginator .current {
    font-weight: var(--font-semibold);
    color: var(--color-base-100);
  }

  /* ===========================
     Archive
     =========================== */
  .archive { list-style: none; margin-bottom: 2rem; }
  .archive li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.375rem 0;
  }
  .archive li a { color: var(--text-normal); font-size: var(--font-small); }
  .archive li a:hover { color: var(--color-accent); }
  .archive-date {
    color: var(--text-faint);
    font-size: var(--font-small);
    min-width: 90px;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .archive-year {
    font-size: 1.25rem;
    font-weight: var(--h2-weight);
    color: var(--color-base-100);
    margin: 1.5rem 0 0.5rem;
    letter-spacing: -0.01em;
  }

  /* ===========================
     Post page
     =========================== */
  .post-header { margin-bottom: 1.5rem; }
  .post-title-main {
    font-size: 2rem;
    font-weight: var(--h1-weight);
    color: var(--color-base-100);
    margin-bottom: 0.5rem;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }
  .post-date {
    color: var(--text-faint);
    font-size: var(--font-small);
  }
  .post-tags-row {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  /* Post back button */
  .post-back {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-l);
    color: var(--text-muted);
    font-size: var(--font-small);
    transition: all var(--anim-fast) var(--ease-out);
  }
  .post-back:hover {
    background: var(--border-color);
    color: var(--text-normal);
    text-decoration: none;
  }
  .post-back svg {
    width: 8px;
    height: 14px;
    margin-right: 0.5rem;
    transition: transform var(--anim-fast) var(--ease-out);
  }
  .post-back:hover svg { transform: translateX(-3px); }

  /* ===========================
     Article typography
     =========================== */
  article { }

  article h1 { font-size: var(--h1-size); font-weight: var(--h1-weight); color: var(--color-base-100); margin: 2rem 0 0.75rem; letter-spacing: -0.03em; line-height: 1.2; }
  article h2 { font-size: var(--h2-size); font-weight: var(--h2-weight); color: var(--color-base-100); margin: 1.75rem 0 0.625rem; letter-spacing: -0.02em; }
  article h3 { font-size: var(--h3-size); font-weight: var(--h3-weight); color: var(--color-base-90); margin: 1.5rem 0 0.5rem; letter-spacing: -0.01em; }
  article h4 { font-size: var(--h4-size); font-weight: var(--h4-weight); color: var(--color-base-90); margin: 1.25rem 0 0.5rem; }
  article h5 { font-size: var(--h5-size); font-weight: var(--h5-weight); color: var(--color-base-80); margin: 1rem 0 0.375rem; }
  article h6 { font-size: var(--h6-size); font-weight: var(--h6-weight); color: var(--color-base-70); margin: 1rem 0 0.375rem; }

  article p { margin: 0.75rem 0; }

  article blockquote {
    border-left: 0.1875rem solid var(--text-faint);
    padding-left: 1rem;
    color: var(--text-muted);
    margin: 1rem 0;
  }

  article ul, article ol { padding-left: 1.5rem; margin: 0.75rem 0; }
  article li { margin: 0.25rem 0; }

  article hr {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 2rem 0;
  }

  article img { max-width: 100%; border-radius: var(--radius-s); }

  /* Links in article */
  article a {
    color: var(--color-accent);
    box-shadow: 0 1px 0 var(--color-accent);
    transition: color var(--anim-fast) var(--ease-out), box-shadow var(--anim-fast) var(--ease-out);
  }
  article a:hover { color: var(--color-accent-1); box-shadow: 0 2px 0 var(--color-accent-1); text-decoration: none; }

  /* ===========================
     Code
     =========================== */
  article code, pre code {
    font-family: var(--font-mono);
  }

  article :not(pre) > code {
    background: oklch(0% 0 0 / 0.04);
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-xs);
    font-size: 0.9em;
    border: 1px solid var(--border-color);
  }

  @media (prefers-color-scheme: dark) {
    article :not(pre) > code {
      background: oklch(100% 0 0 / 0.06);
    }
  }

  article pre {
    background: oklch(13% 0 0);
    padding: 1rem;
    border-radius: var(--radius-m);
    overflow-x: auto;
    margin: 1rem 0;
    box-shadow: var(--shadow-card);
    border: 1px solid oklch(100% 0 0 / 0.05);
  }
  article pre code {
    background: none;
    padding: 0;
    color: oklch(85% 0 0);
    font-size: var(--font-small);
  }

  /* ===========================
     Table
     =========================== */
  article table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: var(--font-small);
  }
  article th, article td {
    border: 1px solid var(--border-color);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  article th {
    background: var(--border-color);
    font-weight: var(--font-medium);
    color: var(--text-normal);
  }

  /* ===========================
     Responsive
     =========================== */
  @media (max-width: 640px) {
    .paper { padding: 2vw; }
    .paper-main {
      padding: 2rem 1.25rem 0;
      border-radius: var(--radius-m);
    }
    .header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .nav { gap: 1rem; }
    .post-title-main { font-size: 1.5rem; }
    article h1 { font-size: 1.5rem; }
    article h2 { font-size: 1.25rem; }
  }

  /* ===========================
     Selection
     =========================== */
  ::selection {
    background: oklab(from var(--color-accent) l a b / 0.15);
  }
</style>
