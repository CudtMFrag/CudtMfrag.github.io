---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const slug = post.id.replace(/\.md$/, '');
const permalink = `/${post.data.date.getFullYear()}/${String(post.data.date.getMonth() + 1).padStart(2, '0')}/${String(post.data.date.getDate()).padStart(2, '0')}/${slug}/`;
---

<BaseLayout title={post.data.title}>
  <article>
    <div class="post-header">
      <h1 class="post-title-main">{post.data.title}</h1>
      <div class="post-date">
        {post.data.date.toISOString().slice(0, 10)}
        {post.data.updated && <> (更新于 {post.data.updated.toISOString().slice(0, 10)})</>}
      </div>
      {post.data.tags.length > 0 && (
        <div class="post-tags-row">
          {post.data.tags.map(tag => <a class="tag-badge" href={`/tags/${tag}/`}>#{tag}</a>)}
        </div>
      )}
    </div>
    <Content />
  </article>
  <nav style="margin-top: 2rem;">
    <a href="javascript:history.back()">&larr; 返回</a>
  </nav>
</BaseLayout>
