---
import BaseLayout from './BaseLayout.astro';
import GiscusComment from '@components/GiscusComment.astro';
import { render, type CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const slug = post.id.replace(/\.md$/, '');
const permalink = `/${post.data.date.getFullYear()}/${String(post.data.date.getMonth() + 1).padStart(2, '0')}/${String(post.data.date.getDate()).padStart(2, '0')}/${slug}/`;
---

<BaseLayout title={post.data.title}>
  <article>
    <div class="post-header">
      <div class="post-date">
        {post.data.date.toISOString().slice(0, 10)}
        {post.data.updated && <span> &middot; 更新于 {post.data.updated.toISOString().slice(0, 10)}</span>}
      </div>
      {post.data.tags.length > 0 && (
        <div class="post-tags-row">
          {post.data.tags.map(tag => <a class="tag-badge" href={`/tags/${tag}/`}>#{tag}</a>)}
        </div>
      )}
    </div>
    <Content />
  </article>

  <nav style="margin-top: 3rem;">
    <a class="post-back" href="javascript:history.back()">
      <svg width="8" height="14" viewBox="0 0 8 14">
        <path d="M7 1L1 7l6 6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      返回
    </a>
  </nav>

  <GiscusComment />
</BaseLayout>
